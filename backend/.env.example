# ============================================================
# RAG Enterprise QA — 环境配置模板
# 复制为 .env 后填写实际值：cp .env.example .env
# ============================================================

# --- MiMo LLM API（订阅版） ---
# 订阅版 Token 以 tp- 开头，普通版以 sk- 开头
MIMO_API_KEY=tp-your-key-here
# 订阅版 API 地址
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# 普通版 API 地址（二选一，取消注释下面这行）：
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# --- Embedding & Reranker 模型 ---
# BGE 中文 embedding（512 维），首次运行自动下载到 ./models/
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# BGE 英文 embedding（768 维），可选切换
# ENGLISH_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- 本地存储 ---
CHROMA_PATH=../data/chroma_db
MODEL_CACHE_PATH=./models

# --- 语言模型缓存（从 ModelScope 下载，国内更快） ---
# 首次运行前执行：
#   python download_models.py
# 或设置环境变量优先从 ModelScope 下载：
# HF_ENDPOINT=https://hf-mirror.com
